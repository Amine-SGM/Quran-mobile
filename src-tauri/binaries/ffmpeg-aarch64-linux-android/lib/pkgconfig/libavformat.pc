prefix=/teamspace/studios/this_studio/ffmpeg-android/ffmpeg-android-maker/build/ffmpeg/arm64-v8a
exec_prefix=${prefix}
libdir=/teamspace/studios/this_studio/ffmpeg-android/ffmpeg-android-maker/build/ffmpeg/arm64-v8a/lib
includedir=/teamspace/studios/this_studio/ffmpeg-android/ffmpeg-android-maker/build/ffmpeg/arm64-v8a/include

Name: libavformat
Description: FFmpeg container format library
Version: 62.12.100
Requires: 
